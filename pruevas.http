###############################################
### SECCIÓN 9 — PRUEBAS DE SEGURIDAD: Tags (Step 4 - opción B, TagPolicy)
###############################################
# ⚠️ IMPORTANTE: si corriste `migrate:fresh --seed`, los tokens de la sección
# anterior ya NO sirven (la tabla personal_access_tokens se vació).
# Ejecutá primero 1.5 (loginTest) y 1.6 (loginAna) y pegá los tokens nuevos
# arriba en las variables @tokenTest y @tokenAna.
#
# IDs esperados después del seeder:
#   Tag 1 → "urgente"     → de Test
#   Tag 2 → "importante"  → de Ana
#   Tag 3 → "rápido"      → de Luis

@tagTest = 1
@tagAna = 2

### 9.1 Test lista sus tags (debe ver SOLO "urgente")
GET {{host}}/tags
Accept: application/json
Authorization: Bearer {{tokenTest}}

### 9.2 Ana lista sus tags (debe ver SOLO "importante")
GET {{host}}/tags
Accept: application/json
Authorization: Bearer {{tokenAna}}

### 9.3 Test SÍ puede ver su propio tag (200)
GET {{host}}/tags/{{tagTest}}
Accept: application/json
Authorization: Bearer {{tokenTest}}

### 9.4 Test intenta VER tag de Ana (debe dar 403)
GET {{host}}/tags/{{tagAna}}
Accept: application/json
Authorization: Bearer {{tokenTest}}

### 9.5 Test intenta EDITAR tag de Ana (debe dar 403)
PUT {{host}}/tags/{{tagAna}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "name": "robado",
    "color": "#000000"
}

### 9.6 Test intenta BORRAR tag de Ana (debe dar 403)
DELETE {{host}}/tags/{{tagAna}}
Accept: application/json
Authorization: Bearer {{tokenTest}}

### 9.7 Test crea un tag (user_id se asigna solo, 201)
POST {{host}}/tags
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "name": "personal",
    "color": "#22c55e"
}

### 9.8 Hack attempt - Test intenta crear con user_id=999 (debe ignorarlo)
# Aunque mande user_id=999, debe guardarse con user_id del token (= 1).
POST {{host}}/tags
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "name": "hack",
    "color": "#ff0000",
    "user_id": 999
}

### 9.9 Hack attempt - Test intenta cambiar el dueño de su tag vía update
# user_id NO está en $fillable → debe ignorarse, el tag sigue siendo de Test.
PUT {{host}}/tags/{{tagTest}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "name": "urgente",
    "color": "#ef4444",
    "user_id": 2
}

### 9.10 Validación - color inválido (debe dar 422)
# El regex exige #RRGGBB exacto. "rojo" no matchea.
POST {{host}}/tags
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "name": "color malo",
    "color": "rojo"
}

### 9.11 Validación - color de 4 dígitos (debe dar 422)
POST {{host}}/tags
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "name": "color corto",
    "color": "#fff"
}

### 9.12 Unique compuesto - Test intenta repetir un nombre suyo (debe dar 500 o 422)
# Como ya existe el tag "urgente" para Test (del seeder), violaría el índice
# unique(['user_id', 'name']). En PostgreSQL devuelve error de constraint.
POST {{host}}/tags
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "name": "urgente",
    "color": "#ef4444"
}

### 9.13 Unique compuesto - Ana SÍ puede usar el nombre "urgente" (201)
# El índice es compuesto (user_id + name), no global. Ana puede tener
# un tag llamado "urgente" porque pertenece a otro user.
POST {{host}}/tags
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenAna}}

{
    "name": "urgente",
    "color": "#ef4444"
}

### 9.14 Test SÍ puede editar su propio tag (200)
PUT {{host}}/tags/{{tagTest}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "name": "muy urgente",
    "color": "#dc2626"
}

### 9.15 Test SÍ puede borrar su propio tag (200)
# Ojo: si tu tag está asociado a tasks (via tag_task), el delete elimina
# las filas de la tabla pivote en cascada (lo configuramos en la migración).
DELETE {{host}}/tags/{{tagTest}}
Accept: application/json
Authorization: Bearer {{tokenTest}}


###############################################
### SECCIÓN 10 — VALIDACIÓN CRUZADA en TaskController (Step 4.6)
###############################################
# Prueba que el user NO pueda asociar a sus tasks recursos de otros users:
# - category_id de otro user → 422
# - tag_ids con algún tag de otro user → 422
# Y que SÍ funcione con sus propios IDs.
#
# Pre-requisitos (después de migrate:fresh --seed):
#   user_id=1 (Test):  category_id=1 ("Trabajo"),  tag_id=1 ("urgente")
#   user_id=2 (Ana):   category_id=2 ("Personal"), tag_id=2 ("importante")
#   user_id=3 (Luis):  category_id=3 ("Estudios"), tag_id=3 ("rápido")
#
# Re-loguear y actualizar @tokenTest / @tokenAna después de cada migrate:fresh.

### 10.1 Test crea task con SU category y SUS tags (201)
POST {{host}}/tasks
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "title": "Task con tags propios",
    "category_id": 1,
    "priority": "medium",
    "tag_ids": [1]
}

### 10.2 Test intenta usar category_id de Ana (debe dar 422)
POST {{host}}/tasks
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "title": "Task con categoría ajena",
    "category_id": 2
}

### 10.3 Test intenta usar tag_id de Ana (debe dar 422)
POST {{host}}/tasks
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "title": "Task con tag ajeno",
    "tag_ids": [2]
}

### 10.4 Test mezcla un tag propio y uno ajeno (debe dar 422)
# Aunque uno sea válido, si CUALQUIERA de los IDs es ajeno → falla.
POST {{host}}/tasks
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "title": "Task con tags mezclados",
    "tag_ids": [1, 2]
}

### 10.5 Test intenta usar tag_id inexistente (debe dar 422)
POST {{host}}/tasks
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "title": "Task con tag inexistente",
    "tag_ids": [9999]
}

### 10.6 Test sin tag_ids ni category_id (debe dar 201)
# Confirma que ambos son opcionales (nullable/sometimes).
POST {{host}}/tasks
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "title": "Task minimal"
}

### 10.7 Test actualiza una de sus tasks reemplazando tags con sync
# Antes: la task creada en 10.1 tiene tag_ids=[1]. Después: tag_ids=[].
# `sync([])` borra todos los tags asociados.
# Ajustá el ID en la URL al ID real que devolvió 10.1.update
PUT {{host}}/tasks/4
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "tag_ids": []
}

### 10.8 Test PUT sin tag_ids → NO toca la tabla pivote
# Diferencia clave con 10.7: si NO mandás la clave, no se ejecuta sync().
# El controller usa $request->has('tag_ids') para distinguir.
PUT {{host}}/tasks/4
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "status": "completed"
}

### 10.9 Test intenta cambiar category_id por una de Ana (debe dar 422)
PUT {{host}}/tasks/4
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "category_id": 2
}

### 10.10 Hack mass assignment - mandar user_id en body (debe ignorarlo)
# Como sacamos user_id del $fillable de Task, queda ignorado silenciosamente.
POST {{host}}/tasks
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{tokenTest}}

{
    "title": "Hack mass assignment",
    "user_id": 999
}
