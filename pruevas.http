###############################################
### VARIABLES BASE
###############################################
@host = http://localhost:8000/api


###############################################
### SECCIÓN 1 — AUTH (Registro y Login)
###############################################

### 1.1 Registro Usuario A
# @name registerA
POST {{host}}/register
Content-Type: application/json
Accept: application/json

{
    "name": "Usuario A",
    "email": "userA@test.com",
    "password": "password123",
    "password_confirmation": "password123"
}

### 1.2 Registro Usuario B
# @name registerB
POST {{host}}/register
Content-Type: application/json
Accept: application/json

{
    "name": "Usuario B",
    "email": "userB@test.com",
    "password": "password123",
    "password_confirmation": "password123"
}

### 1.3 Login Usuario A (si ya existe)
# @name loginA
POST {{host}}/login
Content-Type: application/json
Accept: application/json

{
    "email": "userA@test.com",
    "password": "password123"
}

### 1.4 Login Usuario B (si ya existe)
# @name loginB
POST {{host}}/login
Content-Type: application/json
Accept: application/json

{
    "email": "userB@test.com",
    "password": "password123"
}

### 1.5 Login Test (seeded - dueño de "Trabajo")
# @name loginTest
POST {{host}}/login
Content-Type: application/json
Accept: application/json

{
    "email": "test@example.com",
    "password": "password"
}

### 1.6 Login Ana (seeded - dueña de "Personal")
# @name loginAna
POST {{host}}/login
Content-Type: application/json
Accept: application/json

{
    "email": "ana@example.com",
    "password": "password"
}

### 1.7 Logout (cierra el token actual)
POST {{host}}/logout
Accept: application/json
Authorization: Bearer {{tokenTest}}

### 1.8 Obtener el usuario autenticado
GET {{host}}/user
Accept: application/json
Authorization: Bearer {{tokenTest}}


